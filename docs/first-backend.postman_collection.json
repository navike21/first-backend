              "body": "{\n  \"success\": true,\n  \"code\": \"AUTH_SESSIONS_LIST\",\n  \"data\": [\n    {\n      \"userAgent\": \"Mozilla/5.0...\",\n      \"ip\": \"127.0.0.1\",\n      \"lastSeen\": \"2026-05-02T10:00:00.000Z\"\n    }\n  ]\n}"
            }
