// Prisma Schema v7
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// LANGUAGE SUPPORT
// ============================================
enum Language {
  ES // Español (default)
  EN // English
  FR // Français
  DE // Deutsch
  IT // Italiano
  PT // Português
  KO // 한국어
  JA // 日本語
  ZH // 中文
  RU // Русский
}

// ============================================
// USER MODEL (FIRST Admin System)
// ============================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts Post[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ============================================
// NEWSLETTER MODEL
// ============================================
model Subscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  preferredLang  Language  @default(ES)
  isSubscribed   Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("subscribers")
}

// ============================================
// PORTFOLIO MODELS (Multi-language)
// ============================================
model ProjectCategory {
  id        String   @id @default(uuid())
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  translations ProjectCategoryTranslation[]
  projects     Project[]

  @@map("project_categories")
}

model ProjectCategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  category    ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language    Language
  title       String
  description String?  @db.Text
  coverImage  String?

  @@unique([categoryId, language])
  @@map("project_category_translations")
}

model Project {
  id          String   @id @default(uuid())
  slug        String   @unique
  imageUrl    String?
  demoUrl     String?
  githubUrl   String?
  technologies String[]
  categoryId  String
  category    ProjectCategory @relation(fields: [categoryId], references: [id])
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  translations ProjectTranslation[]

  @@map("projects")
}

model ProjectTranslation {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  language    Language
  title       String
  description String   @db.Text
  content     String   @db.Text

  @@unique([projectId, language])
  @@map("project_translations")
}

// ============================================
// BLOG MODELS (Multi-language)
// ============================================
model BlogCategory {
  id        String   @id @default(uuid())
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  translations BlogCategoryTranslation[]
  posts        Post[]

  @@map("blog_categories")
}

model BlogCategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language    Language
  title       String
  description String?  @db.Text
  coverImage  String?

  @@unique([categoryId, language])
  @@map("blog_category_translations")
}

model Post {
  id          String    @id @default(uuid())
  slug        String    @unique
  coverImage  String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  translations PostTranslation[]
  comments     Comment[]

  @@map("posts")
}

model PostTranslation {
  id       String   @id @default(uuid())
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  language Language
  title    String
  excerpt  String?  @db.Text
  content  String   @db.Text

  @@unique([postId, language])
  @@map("post_translations")
}

model Comment {
  id          String   @id @default(uuid())
  content     String   @db.Text
  authorName  String
  authorEmail String
  language    Language @default(ES)
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("comments")
}

// ============================================
// CONTACT/QUOTES MODEL
// ============================================
model ContactForm {
  id          String        @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  message     String        @db.Text
  language    Language      @default(ES)
  type        ContactType   @default(CONTACT)
  status      ContactStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  respondedAt DateTime?

  @@map("contact_forms")
}

enum ContactType {
  CONTACT
  QUOTE
  SUPPORT
}

enum ContactStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CLOSED
}