{
	"compilerOptions": {
		"target": "es2017",
		"module": "commonjs",
		"rootDir": "./src",
		"outDir": "./dist",
		"removeComments": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@Config/*": ["src/config/*"],
			"@Connection/*": ["src/connection/*"],
			"@Helpers/*": ["src/helpers/*"],
			"@Routes/*": ["src/routes/*"],
			"@Types/*": ["src/libs/types/*"],
			"@Modules/*": ["src/modules/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
