{
	"compilerOptions": {
		"target": "es2021",
		"ignoreDeprecations": "6.0",
		"module": "commonjs",
		"rootDir": "./src",
		"outDir": "./dist",
		"removeComments": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@Config/*": ["src/config/*"],
			"@Connection/*": ["src/connection/*"],
			"@Constants/*": ["src/constants/*"],
			"@Helpers/*": ["src/helpers/*"],
			"@Middlewares/*": ["src/middlewares/*"],
			"@Modules/*": ["src/modules/*"],
			"@Shared/*": ["src/shared/*"],
			"@Types/*": ["src/types/*"],
			"@Routes/*": ["src/routes/*"],
			"@test/*": ["src/test/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
