{
	"version": 2,
	"installCommand": "pnpm install --frozen-lockfile",
	"buildCommand": "pnpm run build",
	"outputDirectory": "public",
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/api/index"
		}
	],
	"functions": {
		"api/index.js": {
			"includeFiles": "node_modules/swagger-ui-dist/**"
		}
	}
}
