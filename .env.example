# Copia este archivo a .env y ajusta los valores según el ambiente
# Ver CLAUDE.md → "Ambientes" para el detalle completo de development/test/producción

PORT=3200

# El frontend local (Vite) corre en el puerto 5176 (vite.config.ts) — deben
# coincidir para que CORS acepte las peticiones del frontend local.
CLIENT_URL=http://localhost:5176
WHITELISTED_DOMAINS=http://localhost:5176

MONGO_APP_NAME=first-backend
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Un solo cluster Atlas, una base de datos por ambiente (ver tabla abajo).
MONGO_URI=
MONGO_DATABASE=first-db__development

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_FROM=no-reply@navike21.com
EMAIL_HOST=mail.navike21.com
EMAIL_PORT=465
EMAIL_USER=no-reply@navike21.com
EMAIL_PASS=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Un secreto distinto por ambiente (development/test/production) — nunca
# reutilizar el mismo secreto entre ambientes.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_SECRET=

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=1h
JWT_EMAIL_EXPIRES=24h
JWT_RESET_EXPIRES=1h

# ─── Referencia de ambientes Vercel (configurar en el dashboard/CLI, no aquí) ─
#
#   Ambiente     | Vercel scope | URL                                              | Mongo DB
#   ─────────────┼──────────────┼──────────────────────────────────────────────────┼───────────────────────
#   Local        | Development  | http://localhost:3200                             | first-db__development
#   Test         | Preview      | https://first-backend-git-test-navike21.vercel.app | first-db__release
#   Production   | Production   | https://first-backend-alpha.vercel.app             | first-db__production
#
#   WHITELISTED_DOMAINS y CLIENT_URL de cada ambiente deben incluir la URL del
#   frontend correspondiente (ver first-frontend/.env.example) para que CORS
#   acepte las peticiones. La rama `test` está pineada como infraestructura
#   (ver TEST_BRANCH.md) para que Vercel siempre tenga un deployment ahí.
