# Production environment
# Copy to .env.production ONLY for local simulation.
# In real production (Vercel/Render/etc), set these as platform env vars.

# Supabase (PROD)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database URLs (PROD)
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@DB_HOST:5432/postgres"

# App
NODE_ENV=production
PORT=3000
JWT_SECRET=change_me
