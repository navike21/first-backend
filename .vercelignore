# .vercelignore - Solo excluir archivos innecesarios PARA EL DEPLOYMENT
# NO excluir src/ ni tsconfig.json (Vercel los necesita para BUILD)

# Development tools (no necesarios en runtime)
node_modules
.env
.env.*
*.log
.git
.vscode
coverage

# Config files (no necesarios en runtime, pero algunos SÍ para build)
.eslintignore
.prettierignore
.prettierrc
.markdownlint.json
nodemon.json

# Lock files
pnpm-lock.yaml

# Documentation (opcional)
README.md
README_VERCEL.md
VERCEL_ARCHITECTURE.md
VERCEL_SETUP.md
