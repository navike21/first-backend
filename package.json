{
	"name": "first-backend",
	"version": "1.0.0",
	"description": "Backend APIs for managing navike21 web ecosystem and services",
	"main": "dist/index.js",
	"scripts": {
		"dev": "nodemon",
		"build": "tsc && tsc-alias",
		"vercel-build": "tsc && tsc-alias",
		"lint": "eslint src/ --ext .ts",
		"format": "prettier --write src/",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --config vitest.config.ts --coverage"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/navike21/first-backend.git"
	},
	"keywords": [
		"express",
		"typescript",
		"vercel",
		"serverless",
		"backend",
		"api"
	],
	"author": "",
	"license": "Apache-2.0",
	"type": "commonjs",
	"bugs": {
		"url": "https://github.com/navike21/first-backend/issues"
	},
	"homepage": "https://github.com/navike21/first-backend#readme",
	"engines": {
		"node": ">=24.x"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/compression": "^1.8.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/nodemailer": "^8.0.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "^10.3.0",
		"globals": "^17.6.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3",
		"supertest": "^6.3.4",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"compression": "^1.8.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"date-fns": "^4.1.0",
		"express": "^5.2.1",
		"express-rate-limit": "^8.4.1",
		"helmet": "^8.1.0",
		"i18next": "^26.0.8",
		"i18next-fs-backend": "^2.6.5",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.6.1",
		"nodemailer": "^8.0.7",
		"socket.io": "^4.8.3",
		"zod": "^4.4.2"
	}
}
